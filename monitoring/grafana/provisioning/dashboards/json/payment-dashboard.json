{
  "title": "결제 모니터링 - 중복결제 차단",
  "uid": "payment-dedup",
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "결제 처리 결과 (status별 누적 건수)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum by (status) (increase(payment_result_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "중복결제 차단 건수 (DUPLICATE)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(payment_result_total{status=\"DUPLICATE\"})"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" } }
      }
    },
    {
      "id": 3,
      "title": "결제 성공 건수 (SUCCESS)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(payment_result_total{status=\"SUCCESS\"})"
        }
      ]
    },
    {
      "id": 4,
      "title": "결제 처리 시간 (P50/P95/P99, payment.processing.duration)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.5, sum(rate(payment_processing_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.95, sum(rate(payment_processing_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.99, sum(rate(payment_processing_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "title": "HTTP 요청 처리량 (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{uri=~\"/api/payments.*\"}[1m]))",
          "legendFormat": "{{uri}} [{{status}}]"
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM 힙 메모리 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "heap used"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 7,
      "title": "애플리케이션 로그 (Loki, com.wanted.backend)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki_ds" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki_ds" },
          "expr": "{job=\"hard-click-backend\"}"
        }
      ]
    }
  ]
}
