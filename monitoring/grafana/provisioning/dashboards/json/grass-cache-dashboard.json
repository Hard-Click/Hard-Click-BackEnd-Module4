{
  "title": "잔디(Grass) 캐싱 — Before/After 대시보드",
  "uid": "hard-click-grass-cache",
  "description": "GET /api/grass/monthly 응답시간 — Redis 캐시 없음/있음 비교 (k6 부하테스트 연동)",
  "tags": ["grass", "cache", "k6", "hard-click"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 39,
  "version": 1,
  "graphTooltip": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m"]
  },

  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "#5794F2",
        "name": "k6 부하테스트 구간",
        "tags": ["k6"],
        "type": "tags"
      }
    ]
  },

  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "GET /api/grass/monthly 응답시간 (P50/P95, ms) — 캐시 없음/있음 비교",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/grass/monthly\"}[30s])) by (le)) * 1000",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/grass/monthly\"}[30s])) by (le)) * 1000",
          "legendFormat": "P50"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "현재 P95 응답시간 (ms)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 50 },
          { "color": "red", "value": 200 }
        ] } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/grass/monthly\"}[30s])) by (le)) * 1000"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "초당 처리 요청 수 (req/s)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/grass/monthly\"}[30s]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "누적 요청 수 (전체)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "afqjyhn1thtdsb" },
          "expr": "sum(http_server_requests_seconds_count{uri=\"/api/grass/monthly\"})"
        }
      ]
    }
  ]
}
