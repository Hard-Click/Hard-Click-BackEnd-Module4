{
  "title": "Hard-Click 게시글·댓글 목록 — N+1 최적화 1~4단계 비교",
  "uid": "hard-click-post-comment-perf",
  "description": "게시글 목록(sort=comments) N+1 / 인덱스 부재 최적화 — Before → ①인덱스 → ②③쿼리전략 → ④비정규화 단계별 비교",
  "tags": ["community", "post", "comment", "k6", "hard-click"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 39,
  "version": 1,
  "graphTooltip": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },

  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "#5794F2",
        "name": "단계 구간 (Before/①/②③/④)",
        "tags": ["stage"],
        "type": "tags"
      }
    ]
  },

  "templating": {
    "list": [
      {
        "name": "rate_interval",
        "type": "interval",
        "label": "집계 간격",
        "hide": 0,
        "auto": true,
        "auto_count": 30,
        "auto_min": "15s",
        "current": { "selected": true, "text": "1m", "value": "1m" },
        "options": [
          { "selected": false, "text": "15s", "value": "15s" },
          { "selected": true,  "text": "1m",  "value": "1m"  },
          { "selected": false, "text": "5m",  "value": "5m"  }
        ],
        "query": "15s,1m,5m"
      }
    ]
  },

  "links": [
    {
      "title": "k6 게시글 목록 부하테스트 스크립트",
      "url": "https://github.com/WantedTeam/Hard-Click-BackEnd-Module4/blob/develop/k6_post_list_load_test.js",
      "icon": "external link",
      "targetBlank": true,
      "includeVars": false,
      "keepTime": true,
      "type": "link"
    }
  ],

  "panels": [

    {
      "id": 99,
      "type": "text",
      "title": "",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## 📋 게시글·댓글 목록 N+1 최적화 — 실시간 측정 대시보드\n이 대시보드는 `GET /api/boards/{boardType}/posts?sort=comments` 게시글 목록 조회의 N+1 / 인덱스 부재 문제를 **Before → ① 인덱스 → ② Batch IN → ③ JOIN → ④ 비정규화** 4가지 방법으로 단계별 개선하는 과정을 실시간으로 보여줍니다. SLO 목표: **P95 ≤ 1초, 에러율 < 1%**"
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },

    {
      "id": 100,
      "type": "row",
      "title": "🔑  핵심 KPI — SLO 판정 기준",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }
    },

    {
      "id": 2,
      "title": "지금 평균 응답시간",
      "description": "지금 이 순간의 평균 응답시간. 정확한 P95는 k6 콘솔 값을 기록표에 사용하세요.",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(http_server_requests_seconds_sum{uri=\"/api/boards/{boardType}/posts\"}[$rate_interval])) / sum(rate(http_server_requests_seconds_count{uri=\"/api/boards/{boardType}/posts\"}[$rate_interval]))",
          "legendFormat": "평균"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "min": 0,
          "max": 5,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 0.7 },
              { "color": "#F2495C", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": { "valueSize": 36, "titleSize": 15 }
      }
    },

    {
      "id": 3,
      "title": "지금 에러율 (200 외 응답)",
      "description": "지금 이 순간의 에러율. SLO-4-2 기준: 1% 미만",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/boards/{boardType}/posts\", status!=\"200\"}[$rate_interval])) / sum(rate(http_server_requests_seconds_count{uri=\"/api/boards/{boardType}/posts\"}[$rate_interval])) * 100",
          "legendFormat": "에러율"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 1 },
              { "color": "#F2495C", "value": 5 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "text": { "valueSize": 52, "titleSize": 15 }
      }
    },

    {
      "id": 4,
      "title": "현재 TPS",
      "description": "초당 게시글 목록 조회 처리량",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/boards/{boardType}/posts\"}[$rate_interval]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "text": { "valueSize": 52, "titleSize": 15 }
      }
    },

    {
      "id": 160,
      "type": "row",
      "title": "⚡  Before vs 최신 확정 단계 — k6 측정 완료값 기준 (항상 정확함)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 }
    },

    {
      "id": 60,
      "title": "Before (풀스캔, 고정값)",
      "description": "최초 측정값(k6 평균 응답시간) — 인덱스/쿼리 최적화 전 기준선",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "vector(31.56)",
          "legendFormat": "Before",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "#F2495C" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }] },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "text": { "valueSize": 56, "titleSize": 16 }
      }
    },

    {
      "id": 61,
      "title": "최신 확정 단계 (평균 응답시간)",
      "description": "가장 마지막에 측정 완료된 단계의 k6 평균 응답시간 — 단계 끝날 때마다 제가 직접 갱신합니다 (라이브 쿼리 아님, 항상 정확)",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "vector(0.15447)",
          "legendFormat": "① 인덱스 (최신)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 0.7 },
              { "color": "#F2495C", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "text": { "valueSize": 56, "titleSize": 16 }
      }
    },

    {
      "id": 62,
      "title": "개선율 (Before 대비)",
      "description": "(Before - 최신 단계) / Before × 100 — 고정값 기반 계산, 항상 정확",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "vector((31.56 - 0.15447) / 31.56 * 100)",
          "legendFormat": "개선율",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#FADE2A", "value": 50 },
              { "color": "#73BF69", "value": 90 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "text": { "valueSize": 56, "titleSize": 16 }
      }
    },

    {
      "id": 150,
      "type": "row",
      "title": "🏆  단계별 비교 — Before → ① → ②③ → ④ (측정 완료된 단계만 표시)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },

    {
      "id": 50,
      "title": "단계별 P95 비교",
      "description": "각 단계 k6 측정이 끝날 때마다 막대가 하나씩 추가됩니다.\n빨간 영역(1초 이상) = SLO 초과, 초록 영역 = SLO 통과",
      "type": "bargauge",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "vector(45.16)",
          "legendFormat": "Before (풀스캔)",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "vector(0.32659)",
          "legendFormat": "① 인덱스",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 0.7 },
              { "color": "#F2495C", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 28,
        "text": { "titleSize": 16, "valueSize": 22 }
      }
    },

    {
      "id": 200,
      "type": "row",
      "title": "📊  응답시간 추이 — Before → ① → ②③ → ④ 한 화면 비교",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 }
    },

    {
      "id": 5,
      "title": "응답시간 추이 (평균 / P95)",
      "description": "단계 전환마다 그래프에 Annotation을 찍어두면, 시간 범위를 넓게 잡았을 때\n각 단계 구간에서 라인이 떨어지는 모습으로 최적화 효과가 한 화면에 보임",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(http_server_requests_seconds_sum{uri=\"/api/boards/{boardType}/posts\"}[$rate_interval])) / sum(rate(http_server_requests_seconds_count{uri=\"/api/boards/{boardType}/posts\"}[$rate_interval]))",
          "legendFormat": "평균 응답시간"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "max(http_server_requests_seconds{uri=\"/api/boards/{boardType}/posts\", quantile=\"0.95\"})",
          "legendFormat": "P95 (SLO 기준)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(242, 73, 92, 0.1)", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "평균 응답시간" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#8AB8FF", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95 (SLO 기준)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#FADE2A", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["last", "max", "mean"] }
      }
    },

    {
      "id": 300,
      "type": "row",
      "title": "🛢  DB 커넥션풀 — 풀스캔 시 포화 여부",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }
    },

    {
      "id": 6,
      "title": "HikariCP 커넥션 풀",
      "description": "Pending(대기) 급증 = 쿼리가 너무 오래 걸려 커넥션이 안 풀린다는 증거\nBefore 단계에서 Active=Max, Pending 급증 예상",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "hikaricp_connections_active",
          "legendFormat": "Active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "hikaricp_connections_idle",
          "legendFormat": "Idle"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "hikaricp_connections_pending",
          "legendFormat": "Pending (대기중)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "hikaricp_connections_max",
          "legendFormat": "Max (풀 한계)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "transparent", "value": null }]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Active" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Pending (대기중)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 50 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Max (풀 한계)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true,
          "calcs": ["last", "max"] }
      }
    },

    {
      "id": 7,
      "title": "CPU 사용률",
      "description": "풀스캔(Before)일 때 CPU가 더 타는지 확인",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "process_cpu_usage * 100",
          "legendFormat": "CPU 사용률"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "showPoints": "never"
          },
          "color": { "mode": "fixed", "fixedColor": "#FF9830" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "transparent", "value": null }]
          },
          "mappings": []
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true,
          "calcs": ["last", "max", "mean"] }
      }
    }

  ]
}
