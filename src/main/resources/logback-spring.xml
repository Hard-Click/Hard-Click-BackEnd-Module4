<?xml version="1.0" encoding="UTF-8"?>


<configuration>

    <!-- ===================================================== -->
    <!-- 1. 공통 속성 설정 -->
    <!-- ===================================================== -->
    <property name="LOG_PATH" value="./logs"/>
    <property name="LOG_FILE_NAME" value="hard-click"/>

    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan([%X{traceId:-}]) %yellow(%logger{36}) - %msg%n"/>

    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-}] [%X{method:-}] [%X{requestURI:-}] [%X{remoteAddr:-}] %logger{36} - %msg%n"/>

    <!-- ===================================================== -->
    <!-- 2. Appender 설정 -->
    <!-- ===================================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <appender name="BUSINESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}-business.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId:-}] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-business.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <appender name="PERFORMANCE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}-performance.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId:-}] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-performance.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ===================================================== -->
    <!-- 3. 개발 환경 설정 (dev) -->
    <!-- ===================================================== -->
    <springProfile name="local,dev,default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>

        <!-- 1. 애플리케이션 전체 로그 (attend, board 등 모든 도메인 포함) -->
        <logger name="com.wanted.backend"
                level="DEBUG"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <!-- 2. 비즈니스 전용 커스텀 로거 (도메인 무관) -->
        <!-- 사용법: Logger bizLog = LoggerFactory.getLogger("BUSINESS_LOG"); -->
        <logger name="BUSINESS_LOG"
                level="INFO"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="BUSINESS_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <!-- 3. AOP 성능 및 예외 로깅 -->
        <logger name="com.wanted.backend.global.aspect.LoggingAspect"
                level="INFO"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="PERFORMANCE_FILE"/>
        </logger>

        <!-- 외부 라이브러리 로그 -->
        <logger name="org.springframework" level="INFO"/>
        <logger name="org.springframework.web" level="DEBUG"/>
        <logger name="org.springframework.transaction" level="DEBUG"/>
        <logger name="org.hibernate" level="INFO"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>
    </springProfile>

    <!-- ===================================================== -->
    <!-- 4. 운영 환경 설정 (prod) -->
    <!-- ===================================================== -->
    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>

        <!-- 운영 환경 애플리케이션 전체 (INFO 유지) -->
        <logger name="com.wanted.backend"
                level="INFO"
                additivity="false">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <!-- 운영 환경 비즈니스 전용 커스텀 로거 -->
        <logger name="BUSINESS_LOG"
                level="INFO"
                additivity="false">
            <appender-ref ref="BUSINESS_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <!-- 운영 환경 AOP 성능 로깅 (성능 저하 방지를 위해 WARN 제한) -->
        <logger name="com.wanted.backend.global.aspect.LoggingAspect"
                level="WARN"
                additivity="false">
            <appender-ref ref="PERFORMANCE_FILE"/>
        </logger>

        <!-- 외부 라이브러리 로그 최소화 -->
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="com.zaxxer.hikari" level="WARN"/>
    </springProfile>

    <!-- ===================================================== -->
    <!-- 5. 테스트 환경 설정 (test) -->
    <!-- ===================================================== -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.wanted.backend"
                level="DEBUG"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <logger name="org.springframework.test" level="WARN"/>
        <logger name="org.springframework.boot.test" level="WARN"/>
    </springProfile>

</configuration>